tbf.BackgroundColor3 = Color3.fromRGB(13,13,20); tbf.BorderSizePixel = 0; tbf.Parent = tb

local function dot(col, x)
    local d = Instance.new("Frame")
    d.Size = UDim2.new(0,11,0,11); d.Position = UDim2.new(0,x,0.5,-5.5)
    d.BackgroundColor3 = col; d.BorderSizePixel = 0; d.ZIndex = 22; d.Parent = tb; co(d,6)
end
dot(Color3.fromRGB(255,95,87),  14)
dot(Color3.fromRGB(254,188,46), 31)
dot(Color3.fromRGB(40,200,64),  48)

local function tbLbl(txt, col, x, w, bold)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0,w,1,0); l.Position = UDim2.new(0,x,0,0)
    l.BackgroundTransparency = 1; l.Text = txt; l.TextColor3 = col
    l.TextSize = 13; l.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
    l.TextXAlignment = Enum.TextXAlignment.Left; l.ZIndex = 22; l.Parent = tb
end
tbLbl("Hawixs", Color3.fromRGB(230,230,245), 70,  65, true)
tbLbl("Script", Color3.fromRGB(139,92,246),  132, 55, true)

local ver = Instance.new("TextLabel")
