switchTab("Movement")

-- ====== Логика ======
local flyBV = nil
RunService.Heartbeat:Connect(function()
    local char=player.Character; if not char then return end
    local hum=char:FindFirstChildOfClass("Humanoid")
    local root=char:FindFirstChild("HumanoidRootPart")
    if hum then hum.WalkSpeed=S.speed; hum.JumpPower=S.jump end
    if S.noclip then
        for _,p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=false end
        end
    end
    if S.fly and root then
        if not flyBV then
            flyBV = Instance.new("BodyVelocity")
            flyBV.MaxForce = Vector3.new(1e5,1e5,1e5)
            flyBV.Velocity = Vector3.zero; flyBV.Parent = root
        end
        local cam=workspace.CurrentCamera; local dir=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir+=cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir-=cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir-=cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir+=cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)       then dir+=Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir-=Vector3.new(0,1,0) end
        flyBV.Velocity = dir.Magnitude>0 and dir.Unit*50 or Vector3.zero
    elseif flyBV then
        flyBV:Destroy(); flyBV=nil
    end
end)

UserInputService.JumpRequest:Connect(function()
    if not S.infJump then return end
    local c=player.Character; local h=c and c:FindFirstChildOfClass("Humanoid")
    if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
end)

-- ====== Открытие/закрытие с анимацией ======
local menuOpen = false

local function openMenu()
    menuOpen = true
    win.Visible = true
    win.Size = UDim2.new(0,500,0,0)
    win.BackgroundTransparency = 1
    tween(win,{Size=UDim2.new(0,500,0,386), BackgroundTransparency=0}, 0.28)
end

local function closeMenu()
    menuOpen = false
    tween(win,{Size=UDim2.new(0,500,0,0), BackgroundTransparency=1}, 0.2)
    task.delay(0.21, function()
        if not menuOpen then win.Visible=false end
    end)
end

UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.KeyCode == Enum.KeyCode.RightShift then
        if menuOpen then closeMenu() else openMenu() end
    end
end)
