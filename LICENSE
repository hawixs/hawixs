keyL.Text = "RShift"; keyL.TextSize = 10; keyL.Font = Enum.Font.Gotham
keyL.BorderSizePixel = 0; keyL.ZIndex = 22; keyL.Parent = tb
co(keyL,5); st(keyL, Color3.fromRGB(25,25,42))

