local plBtn, plBar = makeTabBtn("Player", 52)
local plPanel = makePanel()
panels["Player"] = plPanel; tabBtns["Player"] = {btn=plBtn,bar=plBar}
ndiv(95)
secLabel(plPanel,"ИГРОК")
makeToggle(plPanel,"Бог мод",false,function(v)
    local c=player.Character; local h=c and c:FindFirstChildOfClass("Humanoid")
    if h then h.MaxHealth=v and math.huge or 100; h.Health=h.MaxHealth end
end)
makeToggle(plPanel,"Невидимость",false,function(v)
    local c=player.Character
    if c then for _,p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then p.LocalTransparencyModifier=v and 1 or 0 end end end
end)
makeSlider(plPanel,"Здоровье",0,100,100,function(v)
    local c=player.Character; local h=c and c:FindFirstChildOfClass("Humanoid")
    if h then h.Health=v end
end)
makeToggle(plPanel,"Урон x2",false,function(v) end)
plBtn.MouseButton1Click:Connect(function() switchTab("Player") end)

-- ====== ESP ======
local espBtn, espBar = makeTabBtn("ESP", 96)
local espPanel = makePanel()
panels["ESP"] = espPanel; tabBtns["ESP"] = {btn=espBtn,bar=espBar}
ndiv(139)

local espData = {}
local espEnabled, espNames, espHealth = false, false, false
local espColor = Color3.fromRGB(167,139,250)

local function clearESP()
    for _,d in pairs(espData) do
        if d.hl  then d.hl:Destroy()  end
        if d.bb  then d.bb:Destroy()  end
    end
    espData = {}
end

local function buildESP()
    clearESP()
    if not espEnabled then return end
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local char = p.Character
            local hl = Instance.new("Highlight")
            hl.FillColor = espColor
            hl.OutlineColor = espColor
            hl.FillTransparency = 0.6
            hl.OutlineTransparency = 0
            hl.Adornee = char
            hl.Parent = char
            local bb = nil
            if espNames then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    bb = Instance.new("BillboardGui")
                    bb.Size = UDim2.new(0,120,0,28)
                    bb.StudsOffset = Vector3.new(0,3.5,0)
                    bb.AlwaysOnTop = true
                    bb.Parent = root
                    local lbl = Instance.new("TextLabel",bb)
                    lbl.Size = UDim2.new(1,0,1,0)
                    lbl.BackgroundTransparency = 1
                    lbl.Text = p.Name
                    lbl.TextColor3 = espColor
                    lbl.TextSize = 13
                    lbl.Font = Enum.Font.GothamBold
                end
            end
            espData[p.UserId] = {hl=hl, bb=bb}
        end
    end
end

secLabel(espPanel,"ПОДСВЕТКА")
makeToggle(espPanel,"ESP игроков",false,function(v) espEnabled=v; buildESP() end)
makeToggle(espPanel,"Имена над головой",false,function(v) espNames=v; buildESP() end)
makeToggle(espPanel,"Здоровье ESP",false,function(v) espHealth=v end)
makeSlider(espPanel,"Макс. дистанция",100,1000,500,function(v) end)

espBtn.MouseButton1Click:Connect(function() switchTab("ESP") end)

Players.PlayerRemoving:Connect(function(p)
    if espData[p.UserId] then
        if espData[p.UserId].hl then espData[p.UserId].hl:Destroy() end
        if espData[p.UserId].bb then espData[p.UserId].bb:Destroy() end
        espData[p.UserId] = nil
    end
end)

