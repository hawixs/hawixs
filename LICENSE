makeToggle(mvPanel,"Ускорение",true,function(v) end)
makeToggle(mvPanel,"Бесконечный прыжок",false,function(v) S.infJump=v end)
makeToggle(mvPanel,"Нет коллизий",false,function(v) S.noclip=v end)
mvBtn.MouseButton1Click:Connect(function() switchTab("Movement") end)

