ver.BackgroundColor3 = Color3.fromRGB(18,10,38); ver.TextColor3 = Color3.fromRGB(139,92,246)
ver.Text = "v2.0"; ver.TextSize = 10; ver.Font = Enum.Font.GothamBold
ver.BorderSizePixel = 0; ver.ZIndex = 22; ver.Parent = tb
