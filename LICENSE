side.BackgroundColor3 = Color3.fromRGB(11,11,18); side.BorderSizePixel = 0; side.Parent = win
local sf = Instance.new("Frame")
sf.Size = UDim2.new(0,14,1,0); sf.Position = UDim2.new(1,-14,0,0)
sf.BackgroundColor3 = Color3.fromRGB(11,11,18); sf.BorderSizePixel = 0; sf.Parent = side
st(side, Color3.fromRGB(22,22,36))

-- ScrollingFrame
local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1,-130,1,-46); scroll.Position = UDim2.new(0,130,0,46)
scroll.BackgroundTransparency = 1; scroll.BorderSizePixel = 0
scroll.ScrollBarThickness = 3
scroll.ScrollBarImageColor3 = Color3.fromRGB(60,60,90)
scroll.CanvasSize = UDim2.new(0,0,0,0)
scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
scroll.ScrollingDirection = Enum.ScrollingDirection.Y
scroll.ElasticBehavior = Enum.ElasticBehavior.Always
scroll.Parent = win

local contentArea = Instance.new("Frame")
contentArea.Size = UDim2.new(1,0,0,0)
contentArea.AutomaticSize = Enum.AutomaticSize.Y
contentArea.BackgroundTransparency = 1
contentArea.Parent = scroll
local UIList = Instance.new("UIListLayout", contentArea)
UIList.SortOrder = Enum.SortOrder.LayoutOrder
UIList.Padding = UDim.new(0,0)

-- State
local S = {speed=16,jump=50,fly=false,noclip=false,infJump=false,god=false,invis=false}
local acC = Color3.fromRGB(109,40,217)
local acL = Color3.fromRGB(167,139,250)
local panels  = {}
local tabBtns = {}

local function makePanel()
    local p = Instance.new("Frame")
    p.Size = UDim2.new(1,0,0,0); p.AutomaticSize = Enum.AutomaticSize.Y
    p.BackgroundTransparency = 1; p.Visible = false; p.Parent = contentArea
    local l = Instance.new("UIListLayout",p)
    l.SortOrder = Enum.SortOrder.LayoutOrder; l.Padding = UDim.new(0,7)
    local pd = Instance.new("UIPadding",p)
    pd.PaddingLeft = UDim.new(0,14); pd.PaddingRight = UDim.new(0,14)
    pd.PaddingTop = UDim.new(0,14);  pd.PaddingBottom = UDim.new(0,14)
    return p
end

local function switchTab(name)
    scroll.CanvasPosition = Vector2.zero
    for n,p in pairs(panels) do
        if n == name then
            p.Visible = true
            p.Position = UDim2.new(0,0,0,10)
            tween(p, {Position = UDim2.new(0,0,0,0)}, 0.2)
        else
            p.Visible = false
        end
    end
    for n,d in pairs(tabBtns) do
        local on = (n==name)
        tween(d.btn, {TextColor3 = on and acL or Color3.fromRGB(58,58,82)}, 0.15)
        d.btn.BackgroundTransparency = on and 0 or 1
        d.btn.BackgroundColor3 = Color3.fromRGB(22,22,38)
        d.bar.Visible = on
    end
end

local function makeTabBtn(label, yPos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,-4,0,36); btn.Position = UDim2.new(0,0,0,yPos)
    btn.BackgroundTransparency = 1; btn.Text = "       "..label
    btn.TextColor3 = Color3.fromRGB(58,58,82); btn.TextSize = 12
    btn.Font = Enum.Font.Gotham; btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.BorderSizePixel = 0; btn.Parent = side; co(btn,7)
    btn.MouseEnter:Connect(function()
        if btn.TextColor3 ~= acL then tween(btn,{TextColor3=Color3.fromRGB(130,130,160)},0.12) end
    end)
    btn.MouseLeave:Connect(function()
        if btn.TextColor3 ~= acL then tween(btn,{TextColor3=Color3.fromRGB(58,58,82)},0.12) end
    end)
    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0,3,0.55,0); bar.Position = UDim2.new(0,0,0.225,0)
    bar.BackgroundColor3 = acC; bar.BorderSizePixel = 0; bar.Visible = false; bar.Parent = btn; co(bar,2)
    return btn, bar
end

local function card(parent, h)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,h or 38); f.BackgroundColor3 = Color3.fromRGB(13,13,20)
    f.BorderSizePixel = 0; f.Parent = parent; co(f,9); st(f, Color3.fromRGB(22,22,36))
    f.MouseEnter:Connect(function() tween(f,{BackgroundColor3=Color3.fromRGB(17,17,27)},0.15) end)
    f.MouseLeave:Connect(function() tween(f,{BackgroundColor3=Color3.fromRGB(13,13,20)},0.15) end)
    return f
end

local function secLabel(parent, txt)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1,0,0,22); l.BackgroundTransparency = 1; l.Text = txt
    l.TextColor3 = Color3.fromRGB(45,45,68); l.TextSize = 10; l.Font = Enum.Font.GothamBold
    l.TextXAlignment = Enum.TextXAlignment.Left; l.Parent = parent
end

local function makeToggle(parent, label, default, onChange)
    local c = card(parent, 38)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-54,1,0); lbl.Position = UDim2.new(0,12,0,0)
    lbl.BackgroundTransparency = 1; lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(185,185,205); lbl.TextSize = 12
    lbl.Font = Enum.Font.Gotham; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = c
    local isOn = default
    local tog = Instance.new("TextButton")
    tog.Size = UDim2.new(0,38,0,20); tog.Position = UDim2.new(1,-50,0.5,-10)
    tog.BackgroundColor3 = isOn and acC or Color3.fromRGB(28,28,44)
    tog.Text = ""; tog.BorderSizePixel = 0; tog.Parent = c; co(tog,10)
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,14,0,14)
    knob.Position = isOn and UDim2.new(0,22,0.5,-7) or UDim2.new(0,3,0.5,-7)
    knob.BackgroundColor3 = Color3.new(1,1,1); knob.BorderSizePixel = 0; knob.Parent = tog; co(knob,7)
    tog.MouseButton1Click:Connect(function()
        isOn = not isOn
        tween(tog,  {BackgroundColor3 = isOn and acC or Color3.fromRGB(28,28,44)}, 0.15)
        tween(knob, {Position = isOn and UDim2.new(0,22,0.5,-7) or UDim2.new(0,3,0.5,-7)}, 0.15)
        if onChange then onChange(isOn) end
    end)
    return function() return isOn end
end

local function makeSlider(parent, label, mn, mx, def, onChange)
    local c = card(parent, 56)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-60,0,22); lbl.Position = UDim2.new(0,12,0,6)
    lbl.BackgroundTransparency = 1; lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(185,185,205); lbl.TextSize = 12
    lbl.Font = Enum.Font.Gotham; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = c
    local vBox = Instance.new("TextLabel")
    vBox.Size = UDim2.new(0,40,0,18); vBox.Position = UDim2.new(1,-52,0,8)
    vBox.BackgroundColor3 = Color3.fromRGB(18,9,36); vBox.TextColor3 = acL
    vBox.Text = tostring(def); vBox.TextSize = 11; vBox.Font = Enum.Font.GothamBold
    vBox.BorderSizePixel = 0; vBox.Parent = c; co(vBox,5)
    local track = Instance.new("Frame")
    track.Size = UDim2.new(1,-24,0,4); track.Position = UDim2.new(0,12,0,40)
    track.BackgroundColor3 = Color3.fromRGB(24,24,40); track.BorderSizePixel = 0; track.Parent = c; co(track,2)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((def-mn)/(mx-mn),0,1,0)
    fill.BackgroundColor3 = acC; fill.BorderSizePixel = 0; fill.Parent = track; co(fill,2)
    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0,15,0,15); thumb.AnchorPoint = Vector2.new(0.5,0.5)
    thumb.Position = UDim2.new((def-mn)/(mx-mn),0,0.5,0)
    thumb.BackgroundColor3 = Color3.fromRGB(196,181,253); thumb.BorderSizePixel = 0
    thumb.ZIndex = 5; thumb.Parent = track; co(thumb,8); st(thumb, Color3.fromRGB(109,40,217),2)
    local val = def; local drag = false
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true; tween(thumb,{Size=UDim2.new(0,18,0,18)},0.12)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = false; tween(thumb,{Size=UDim2.new(0,15,0,15)},0.12)
        end
    end)
    RunService.Heartbeat:Connect(function()
        if not drag then return end
        local pct = math.clamp((mouse.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        val = math.round(mn+pct*(mx-mn))
        fill.Size = UDim2.new(pct,0,1,0); thumb.Position = UDim2.new(pct,0,0.5,0)
        vBox.Text = tostring(val)
        if onChange then onChange(val) end
    end)
end

local function ndiv(yPos)
    local d = Instance.new("Frame"); d.Size = UDim2.new(1,-18,0,1)
    d.Position = UDim2.new(0,9,0,yPos); d.BackgroundColor3 = Color3.fromRGB(18,18,30)
    d.BorderSizePixel = 0; d.Parent = side
end

